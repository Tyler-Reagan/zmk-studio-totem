#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define BASE 0
#define DEV  1  // Developer Hotpaths (right-hand)
#define SYS  2  // Navigation and Media (right-hand)
#define NUM  3  // Numbers and Symbols (left-hand)
#define FUN  4  // Function Keys (left-hand)
#define BOOT 5  // Bootloader and Reset (both)

#define HYPER &kp LS(LC(LA(LGUI)))

&mt {
  flavor = "tap-preferred";
  tapping-term-ms = <200>;
  display-name = "Mod-Tap";
};

&lt {
  flavor = "tap-preferred";
  tapping-term-ms = <200>;
  display-name = "Layer-Tap";
};

/ {
  keymap {
    compatible = "zmk,keymap";
      base_layer {
        display-name = "Base";
        //                 ┏━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓   ┏━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓
        //                 ┃ Q             ┃ W             ┃ E             ┃ R             ┃ T             ┃   ┃ Y             ┃ U             ┃ I             ┃ O             ┃ P             ┃
        //                 ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫
        //                 ┃ A             ┃ S             ┃ D             ┃ F             ┃ G             ┃   ┃ H             ┃ J             ┃ K             ┃ L             ┃ ;             ┃
        // ┏━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┓
        // ┃ HYPER         ┃ Z             ┃ X             ┃ C             ┃ V             ┃ B             ┃   ┃ N             ┃ M             ┃ ,             ┃ .             ┃ /             ┃ '             ┃
        // ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛
        //                                                 ┃ ESC           ┃ SYS+TAB       ┃ DEV+SPACE     ┃   ┃ BSPC          ┃ NUM+RET       ┃ FUN+DEL       ┃
        //                                                 ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛   ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛
        bindings = <
        // ╷               ╷               ╷               ╷               ╷               ╷               ╷   ╷               ╷               ╷               ╷               ╷               ╷               ╷
                             &kp Q          &kp W           &kp E           &kp R           &kp T               &kp Y           &kp U           &kp I           &kp O           &kp P
                             &kp A          &mt LGUI S      &mt LCTRL D     &mt LSHFT F     &kp G               &kp H           &mt RSHFT J     &mt RCTRL K     &mt RGUI L      &kp SEMI
                             &kp Z          &kp X           &kp C           &kp V           &kp B               &kp N           &kp M           &kp COMMA       &kp DOT         &kp FSLH
            HYPER                                           &kp ESC         &lt SYS TAB     &lt DEV SPACE       &kp BSPC        &lt NUM RET     &lt FUN DEL                                     &kp SQT
        >;
      };

      dev_layer {
        display-name = "Dev";
        //                 ┏━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓   ┏━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓
        //                 ┃               ┃               ┃               ┃               ┃               ┃   ┃ -             ┃ {             ┃ }             ┃ `             ┃ =             ┃
        //                 ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫
        //                 ┃ GUI           ┃ ALT           ┃ CTRL          ┃ SHIFT         ┃               ┃   ┃ _             ┃ [             ┃ ]             ┃ '             ┃ $             ┃
        // ┏━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┓
        // ┃               ┃               ┃               ┃               ┃               ┃               ┃   ┃               ┃ &             ┃ |             ┃ *             ┃               ┃ SHIFT TAB     ┃
        // ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛
        //                                                 ┃               ┃               ┃               ┃   ┃ @             ┃ (             ┃ )             ┃
        //                                                 ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛   ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛
        bindings = <
        // ╷               ╷               ╷               ╷               ╷               ╷               ╷   ╷               ╷               ╷               ╷               ╷               ╷               ╷
                            &none           &none           &none           &none           &none               &kp MINUS       &kp LS(LBKT)    &kp LS(RBKT)    &kp GRAVE       &kp EQUAL
                            &kp LGUI        &kp LALT        &kp LCTRL       &kp LSHFT       &none               &kp LS(MINUS)   &kp LBKT        &kp RBKT        &kp SQT         &kp LS(N4)
                            &none           &none           &none           &none           &none               &none           &kp LS(N7)      &kp BSLH    &kp LS(N8)      &none
            &none                                           &none           &none           &none               &kp LS(N2)      &kp LS(N9)      &kp LS(N0)                                      &kp LS(TAB)
        >;
      };

      sys_layer {
        display-name = "Sys";
        //                 ┏━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓   ┏━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓
        //                 ┃ BT_CLR        ┃ BT_SEL 0      ┃ BT_SEL 1      ┃ BT_SEL 2      ┃               ┃   ┃ SCREENSHOT    ┃ PREV          ┃ VOL-          ┃ VOL+          ┃ NEXT          ┃
        //                 ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫
        //                 ┃ ALT           ┃ SHIFT         ┃ GUI           ┃ CTRL          ┃               ┃   ┃ SCREENSHOT+   ┃ ←             ┃ ↓             ┃ ↑             ┃ →             ┃
        // ┏━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┓
        // ┃ BT_CLR_ALL    ┃               ┃               ┃               ┃               ┃               ┃   ┃ UNDO          ┃ COPY          ┃ PASTE         ┃ CUT           ┃               ┃ LOCK SCREEN   ┃
        // ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛
        //                                                 ┃               ┃               ┃               ┃   ┃ REFRESH       ┃ PLAY          ┃ MUTE          ┃
        //                                                 ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛   ┗━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┻━━━━━━━━━━━━━━━┛
        bindings = <
        // ╷               ╷               ╷               ╷               ╷               ╷               ╷   ╷               ╷               ╷               ╷               ╷               ╷               ╷
                            &bt BT_CLR      &bt BT_SEL 0    &bt BT_SEL 1    &bt BT_SEL 2    &none               &kp LC(LS(N4))  &kp C_PREV      &kp C_VOL_DN    &kp C_VOL_UP    &kp C_NEXT
                            &kp LALT        &kp LSHFT       &kp LGUI        &kp LCTRL       &none               &kp LC(LS(N5))  &kp LEFT        &kp DOWN        &kp UP          &kp RIGHT
                            &none           &none           &none           &none           &none               &none           &kp LC(Z)       &kp LC(X)       &kp LC(C)       &kp LC(V)
            &bt BT_CLR_ALL                                  &none           &none           &none               &kp LC(R)       &kp C_PP        &kp C_MUTE                                      &kp LC(LG(Q))
        >;
      };

      num_layer {
        display-name = "Num";
        //                 ┏━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓   ┏━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓
        //                 ┃ -             ┃ 7             ┃ 8             ┃ 9             ┃               ┃   ┃               ┃               ┃               ┃               ┃               ┃
        //                 ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫   ┣━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━╋━━━━━━━━━━━━━━━┫
        //                 ┃ =             ┃ 4             ┃ 5             ┃ 6             ┃               ┃   ┃               ┃ SHIFT         ┃ CTRL          ┃ ALT           ┃ GUI           ┃
